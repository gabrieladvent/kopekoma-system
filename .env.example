APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Wajib benar: scheduler (backup, reminder angsuran) dan periode laporan
# keuangan mengacu ke timezone ini. Salah timezone menggeser transaksi ke
# periode laporan yang keliru.
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Produksi & dev memakai MySQL. Suite tes memakai SQLite in-memory (dipaksa di
# phpunit.xml), jadi nilai di sini tidak memengaruhi tes.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kopekoma_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Media ────────────────────────────────────────────────────────────────────
# Disk penyimpanan dokumen anggota (KTP/SK), kuitansi, dan bukti bayar.
# WAJIB disk privat. Disk "public" membuat berkas dapat diunduh siapa pun lewat
# /storage/... tanpa autentikasi, melewati seluruh gate permission. Akses harus
# melalui route('media.show') yang mengecek policy pemiliknya.
MEDIA_DISK=local

# ── Seeder ───────────────────────────────────────────────────────────────────
# Kredensial super_admin pertama. WAJIB diisi di produksi — UserSeeder menolak
# jalan tanpa keduanya supaya tidak ada instalasi yang berakhir dengan
# kredensial default yang bisa ditebak. Kosongkan di local/dev.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
